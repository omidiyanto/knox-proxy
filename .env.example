# ============================================================================
# KNOX IAM Gateway — Environment Variables Reference
# ============================================================================
# Copy this file to .env and adjust values for your environment.
# Usage: docker-compose --env-file .env up -d

# --- Timezone ---
GENERIC_TIMEZONE=Asia/Jakarta

# --- OIDC / Keycloak ---
# Keycloak realm issuer URL (REQUIRED)
OIDC_ISSUER_URL=https://sso.perusahaan.com/realms/corp

# OIDC Client ID (registered in Keycloak)
OIDC_CLIENT_ID=n8n-proxy

# OIDC Client Secret (from Keycloak client credentials — REQUIRED)
OIDC_CLIENT_SECRET=your-client-secret-here

# OIDC callback URL (must match Keycloak client "Valid Redirect URIs")
OIDC_REDIRECT_URL=http://localhost:8443/auth/callback

# --- Team Mapping ---
# Keycloak group prefix. Groups matching this prefix are mapped to teams.
# Example: group "/n8n-prod-finance" → team "finance"
KEYCLOAK_GROUP_PREFIX=/n8n-prod-

# JSON mapping of team names to n8n local account credentials.
# Each team needs a pre-created local n8n account.
# Format: {"<team>":{"email":"<n8n_email>","pass":"<n8n_password>"}, ...}
N8N_TEAM_CREDENTIALS={"finance":{"email":"fin@local","pass":"financePwd123"},"developer":{"email":"dev@local","pass":"devPwd456"}}

# --- Security: Dangerous Nodes Blocklist ---
# Default: empty = allow all nodes (no blocking)
# Comma-separated list of n8n node types to block in workflow edits:
DANGEROUS_NODES=
# Or point to a YAML/JSON file:
# DANGEROUS_NODES_FILE=/app/dangerous-nodes.yaml

# --- Vault (Optional — Feature Flag) ---
# Set to true to use HashiCorp Vault instead of N8N_TEAM_CREDENTIALS env var.
ENABLE_VAULT=false
# VAULT_ADDR=https://vault.perusahaan.com:8200
# VAULT_ROLE_ID=xxxxx
# VAULT_SECRET_ID=yyyyy
# VAULT_SECRET_PATH=secret/data/knox/n8n_teams
# VAULT_CACHE_TTL=300

# --- Advanced ---
# How long to cache n8n-auth cookies (seconds)
COOKIE_TTL=3600

# KNOX session max age (seconds)
SESSION_MAX_AGE=3600

# Auto-generated if not set. Set explicitly for multi-instance deployments.
# SESSION_SECRET=your-random-secret-here

# --- UI Features ---
# Show the "JIT Access" menu in the sidebar for requesting just-in-time access.
# Set to "false" to hide the JIT request UI (backend API still works).
KNOX_JIT_ENABLED=true

# Show a full-screen watermark overlay with the logged-in user's name and email.
# Useful for screenshot traceability. Set to "false" to disable.
KNOX_WATERMARK_ENABLED=true

# Show the "Edit" checkbox in the JIT Request modal.
# When "false", only "Run" access type is available — users cannot request edit access.
# Default: true
KNOX_JIT_EDIT_ENABLED=true

# --- JIT Ticketing Database ---
# Password for the KNOX PostgreSQL database used by the JIT ticketing system.
KNOX_DB_PASSWORD=knoxSecurePass

# --- JIT Access Request ---
# Webhook URL for JIT access requests (Knox sends POST here).
# Leave empty to disable webhook notifications (tickets still saved to DB).
JIT_WEBHOOK_URL=https://mywebhook.com/receive

# Maximum allowed request duration in days (default: 7)
JIT_MAX_DURATION_DAYS=7

# --- Admin API ---
# API key for external tools to access /knox-api/admin/* endpoints.
# Generate a secure key: openssl rand -hex 32
KNOX_API_KEY=your-random-api-key-here

# (Optional) When ENABLE_VAULT=true and KNOX_API_KEY is empty,
# Knox reads the API key from Vault instead.
# KNOX_API_KEY_VAULT_PATH=secret/data/knox/config
# KNOX_API_KEY_VAULT_FIELD=knox_api_key
